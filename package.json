{
  "name": "reacttestgen-ai",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "start": "npm --workspace examples/expense-manager run start",
    "start:no-testgen": "npm --workspace examples/expense-manager run start:no-testgen",
    "build": "npm --workspace examples/expense-manager run build",
    "lint": "npm --workspace examples/expense-manager run lint",
    "test": "npm --workspace examples/expense-manager run test",
    "testgen": "npm --workspace examples/expense-manager run testgen",
    "testgen:file": "npm --workspace examples/expense-manager run testgen:file",
    "testgen:git": "npm --workspace examples/expense-manager run testgen:git",
    "docs:generate": "node packages/testgen/scripts/docs/generate-docs.mjs",
    "testgen:all": "npm --workspace examples/expense-manager run testgen:all",
    "testgen:smart": "npm --workspace examples/expense-manager run testgen:smart",
    "testgen:smart:file": "npm --workspace examples/expense-manager run testgen:smart:file",
    "testgen:smart:git": "npm --workspace examples/expense-manager run testgen:smart:git",
    "dev:bulletproof": "npm run dev --prefix examples/bulletproof-react-master/apps/react-vite",
    "dev:bulletproof:no-testgen": "npm run dev:no-testgen --prefix examples/bulletproof-react-master/apps/react-vite",
    "testgen:bulletproof": "npm run testgen:git --prefix examples/bulletproof-react-master/apps/react-vite",
    "testgen:bulletproof:all": "npm run testgen:all --prefix examples/bulletproof-react-master/apps/react-vite",
    "testgen:bulletproof:smart": "npm run testgen:smart --prefix examples/bulletproof-react-master/apps/react-vite",
    "benchmark:testgen": "powershell -NoProfile -ExecutionPolicy Bypass -File packages/testgen/scripts/run-benchmark.ps1",
    "sonar": "npx sonarqube-scanner"
  }
}
