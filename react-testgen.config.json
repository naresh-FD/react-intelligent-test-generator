{
  "version": 1,
  "defaults": {
    "include": [
      "src/**/*.{ts,tsx}"
    ],
    "exclude": [
      "**/__tests__/**",
      "**/*.test.*",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**"
    ],
    "framework": "auto",
    "renderHelper": "auto",
    "generateFor": [
      "components",
      "hooks",
      "utils"
    ],
    "mode": "git-unstaged",
    "testOutput": {
      "strategy": "colocated"
    }
  },
  "packages": [
    {
      "name": "expense-manager",
      "root": "examples/expense-manager",
      "include": [
        "src/**/*.{ts,tsx}"
      ],
      "framework": "jest",
      "renderHelper": "src/test-utils/renderWithProviders.tsx"
    }
  ]
}
